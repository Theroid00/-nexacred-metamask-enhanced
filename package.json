{
  "name": "nexacred-serverless-root",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend/nexacred",
    "dev:backend": "node start-backend.mjs",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run build --prefix frontend/nexacred",
    "build:blockchain": "cd blockchain && npx hardhat compile",
    "build": "npm run build:frontend && npm run build:blockchain",
    "lint:frontend": "npm run lint --prefix frontend/nexacred",
    "lint": "npm run lint:frontend",
    "check": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
