{
  "version": 2,
  "buildCommand": "cd frontend/nexacred && npm install && npm run build",
  "outputDirectory": "frontend/nexacred/dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
